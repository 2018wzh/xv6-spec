  "run": {
    "command": "qemu-system-riscv64",
    "args": [
      "-machine",
      "virt",
      "-bios",
      "none",
      "-kernel",
      "kernel/kernel",
      "-m",
      "128M",
      "-smp",
      "3",
      "-nographic",
      "-global",
      "virtio-mmio.force-legacy=false",
      "-drive",
      "file=fs.img,if=none,format=raw,id=x0",
      "-device",
      "virtio-blk-device,drive=x0,bus=virtio-mmio-bus.0"
